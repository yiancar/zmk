config ZMK_TEST_BEHAVIORS
    bool "Include behaviors used for testing purposes"

config ZMK_TEST_STUDIO_LIGHTING
    bool "Include the Studio lighting RPC handler for native tests"
    depends on ZMK_TEST_BEHAVIORS && ZMK_RGB_UNDERGLOW && SETTINGS
    select NANOPB
    select ZMK_BEHAVIOR_LOCAL_IDS
    select ZMK_KEYMAP_SETTINGS_STORAGE

config ZMK_TEST_STUDIO_RPC_TX
    bool "Exercise Studio RPC TX streaming with a test transport"
    depends on ZMK_TEST_BEHAVIORS
    select ZMK_STUDIO
